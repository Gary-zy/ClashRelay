{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RelayBox",
  "version": "0.1.0",
  "identifier": "com.relaybox.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "RelayBox",
        "width": 1440,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 840,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
